.login-page {
  min-height: 100vh;
  background: linear-gradient(165deg, #4f6ef7 0%, #7c5cfc 40%, #a78bfa 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.login-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.login-logo-wrap {
  margin-bottom: 24rpx;
}

.login-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.logo-text {
  font-size: 56rpx;
  font-weight: 900;
  color: #fff;
}

.login-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 2rpx;
}

.login-card {
  width: 100%;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-sizing: border-box;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.12);
}

.login-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 36rpx;
}

.login-card-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.login-card-label {
  margin-left: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1d2e;
}

.login-input-wrap {
  display: flex;
  align-items: center;
  background: #f4f6fb;
  border: 2rpx solid #e8ecf4;
  border-radius: 18rpx;
  padding: 0 22rpx;
  margin-bottom: 28rpx;
  height: 96rpx;
  box-sizing: border-box;
}

.login-input-icon {
  margin-right: 16rpx;
  display: flex;
  align-items: center;
}

.login-input {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  color: #1a1d2e;
  background: transparent;
  border: none;
  margin-bottom: 0;
  padding: 0;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  border-radius: 18rpx;
  margin-top: 8rpx;
}

.login-dev-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #8b93a7;
}

.login-footer {
  margin-top: 48rpx;
}

.login-footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 1rpx;
}
