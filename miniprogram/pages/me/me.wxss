.profile-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.profile-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.profile-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #f2f4f9;
  border: 3rpx solid #e0e7ff;
  flex-shrink: 0;
}

.profile-text {
  flex: 1;
  min-width: 0;
}

.profile-nickname {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1d2e;
  margin-bottom: 4rpx;
}

.profile-phone {
  font-size: 24rpx;
}

.profile-edit-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f4f6fb;
  color: #4f6ef7;
  font-size: 24rpx;
  font-weight: 600;
}

.profile-edit-form {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.profile-edit-avatar-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-change-avatar-btn {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f6ef7, #7c5cfc);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.profile-edit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.profile-save-btn {
  flex: 1;
}

.profile-cancel-btn {
  flex: 1;
  background: #f4f6fb;
  color: #6b7280;
  border-radius: 16rpx;
  font-weight: 600;
  border: none;
}

.profile-cancel-btn::after {
  border: none;
}

.profile-id-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f2f4f9;
}

.profile-id-value {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
}

.tabs-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.tabs-header {
  display: flex;
  gap: 0;
  margin-bottom: 20rpx;
  background: #f4f6fb;
  border-radius: 16rpx;
  padding: 6rpx;
  overflow: hidden;
}

.tab-switch {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7280;
  transition: all 0.2s;
}

.tab-switch-active {
  background: #fff;
  color: #4f6ef7;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(79, 110, 247, 0.12);
}

.tab-count {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: #e8ecf4;
  color: #6b7280;
}

.tab-switch-active .tab-count {
  background: #eef1ff;
  color: #4f6ef7;
}

.collect-item {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  margin-bottom: 12rpx;
  background: #f8f9fd;
  border: 1rpx solid #e8ecf4;
}

.collect-item-with-img {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.collect-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f2f4f9;
  flex-shrink: 0;
}

.collect-body {
  flex: 1;
  min-width: 0;
}

.collect-item-no-img {
  padding: 4rpx 0;
}

.collect-item-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.collect-item-title {
  font-weight: 700;
  font-size: 28rpx;
  color: #1a1d2e;
  max-width: 65%;
}

.collect-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #eef1ff;
  color: #4f6ef7;
  font-weight: 600;
  border: 1rpx solid #d4d9ff;
  flex-shrink: 0;
}

.collect-summary {
  line-height: 1.6;
  color: #6b7280;
  font-size: 24rpx;
}

.collect-category {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.collect-no-img-hint {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f6fb;
  color: #8b93a7;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.post-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2f4f9;
}

.post-item:last-child {
  border-bottom: none;
}

.post-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.post-item-title {
  font-weight: 600;
  font-size: 28rpx;
  color: #1a1d2e;
  max-width: 65%;
}

.post-item-desc {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.post-item-actions {
  display: flex;
  gap: 12rpx;
}

.post-delete-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1f2;
  color: #e8364e;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #fecdd3;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7280;
}

.logout-btn {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  color: #e8364e;
  font-weight: 700;
  font-size: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
  letter-spacing: 1rpx;
}
