<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.mapper.PostCommentMapper">

    <resultMap id="BaseResultMap" type="com.campus.entity.PostComment">
        <id column="id" property="id"/>
        <result column="post_id" property="postId"/>
        <result column="user_id" property="userId"/>
        <result column="content" property="content"/>
        <result column="parent_id" property="parentId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <resultMap id="CommentRespMap" type="com.campus.dto.response.PostCommentResp">
        <id column="id" property="id"/>
        <result column="post_id" property="postId"/>
        <result column="user_id" property="userId"/>
        <result column="content" property="content"/>
        <result column="parent_id" property="parentId"/>
        <result column="create_time" property="createTime"/>
        <result column="nickname" property="nickname"/>
        <result column="avatar_url" property="avatarUrl"/>
        <result column="reply_to_nickname" property="replyToNickname"/>
    </resultMap>

    <insert id="insert" parameterType="com.campus.entity.PostComment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO post_comment(post_id, user_id, content, parent_id)
        VALUES(#{postId}, #{userId}, #{content}, #{parentId})
    </insert>

    <select id="findByPostId" resultMap="CommentRespMap">
        SELECT c.id, c.post_id, c.user_id, c.content, c.parent_id, c.create_time,
               u.nickname, u.avatar_url,
               pu.nickname AS reply_to_nickname
        FROM post_comment c
        LEFT JOIN user u ON c.user_id = u.id
        LEFT JOIN post_comment pc ON c.parent_id = pc.id
        LEFT JOIN user pu ON pc.user_id = pu.id
        WHERE c.post_id = #{postId}
        ORDER BY c.id ASC
    </select>

    <select id="countByPostId" resultType="long">
        SELECT COUNT(1)
        FROM post_comment
        WHERE post_id = #{postId}
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT id, post_id, user_id, content, parent_id, create_time
        FROM post_comment
        WHERE id = #{id}
        LIMIT 1
    </select>

    <delete id="deleteById">
        DELETE FROM post_comment
        WHERE id = #{id}
    </delete>

</mapper>
