<view class="container" wx:if="{{post}}">
  <view class="detail-header-card">
    <view class="detail-title">{{post.title}}</view>

    <view wx:if="{{post.status === 0 || post.status === 3}}" class="detail-warning detail-warning-orange">
      该帖子因违规已下架，不可点赞评论
    </view>
    <view wx:if="{{post.status === 3}}" class="detail-warning detail-warning-red">
      已被下架
    </view>
    <view wx:if="{{post.status === 0}}" class="detail-warning detail-warning-yellow">
      待审核中，审核通过后可正常互动
    </view>

    <view class="detail-desc-box">
      <view class="detail-desc-label">描述</view>
      <view class="detail-desc-text">{{post.description || '暂无描述'}}</view>
    </view>

    <view class="detail-meta-row">
      <view class="tag">{{categoryLabel}}</view>
      <view class="detail-meta-item muted" wx:if="{{post.price !== null && post.price !== undefined}}">
        <image class="icon-xs" src="/assets/icons/time.svg" mode="aspectFit" />
        <text>价格：￥{{post.price}}</text>
      </view>
      <view class="detail-meta-item muted" wx:if="{{post.contact}}">
        <image class="icon-xs" src="/assets/icons/location.svg" mode="aspectFit" />
        <text>联系方式：{{post.contact}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{imageList.length}}">
    <view class="section-title">图片</view>
    <view class="detail-images">
      <image wx:for="{{imageList}}" wx:key="index" src="{{item}}" mode="aspectFill" class="detail-img" bindtap="previewImage" data-index="{{index}}" />
    </view>
  </view>

  <view wx:if="{{post.status !== 0 && post.status !== 3}}" class="detail-action-bar">
    <view class="detail-action-btn {{liked ? 'detail-action-liked' : ''}}" bindtap="onToggleLike">
      <image class="heart-icon {{likeAnimating ? 'animate-liked' : ''}}" src="{{liked ? '/assets/icons/like-filled.svg' : '/assets/icons/like.svg'}}" mode="aspectFit" />
      <text>{{liked ? '已点赞' : '点赞'}}（{{post.likeCount || 0}}）</text>
    </view>
    <view class="detail-action-btn {{collected ? 'detail-action-collected' : ''}}" bindtap="onToggleCollect">
      <image class="heart-icon {{collectAnimating ? 'animate-liked' : ''}}" src="{{collected ? '/assets/icons/collect-filled.svg' : '/assets/icons/collect.svg'}}" mode="aspectFit" />
      <text>{{collected ? '已收藏' : '收藏'}}（{{post.collectCount || 0}}）</text>
    </view>
    <view class="detail-action-btn">
      <image class="heart-icon" src="/assets/icons/comment.svg" mode="aspectFit" />
      <text>评论 {{post.commentCount || 0}}</text>
    </view>
    <view class="detail-report-btn" bindtap="onReport">举报</view>
  </view>

  <view wx:if="{{post.status !== 0 && post.status !== 3}}" class="detail-comment-input">
    <view class="comment-input-wrap">
      <input class="comment-input" placeholder="输入评论后按发送" value="{{commentContent}}" bindinput="onCommentInput" confirm-type="send" bindconfirm="onAddComment" />
    </view>
  </view>

  <view class="card" wx:if="{{commentList.length}}">
    <view class="section-title">评论列表</view>
    <view wx:for="{{commentList}}" wx:key="id" class="comment-item">
      <image src="{{item.avatarUrl || 'https://via.placeholder.com/88x88.png?text=U'}}" mode="aspectFill" class="comment-avatar" />
      <view class="comment-body">
        <view class="comment-header">
          <view class="comment-nickname">{{item.nickname || ('用户' + item.userId)}}</view>
          <view class="comment-id muted">#{{item.id}}</view>
        </view>
        <view class="comment-content">{{item.content}}</view>
        <view class="comment-time muted">{{item.createTime}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{!commentList.length}}" class="empty-state">
    <view class="empty-icon">💬</view>
    <view class="empty-text">暂无评论</view>
    <view class="empty-hint">快来发表第一条评论吧</view>
  </view>
</view>

<view wx:else class="container">
  <view class="loading-card">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>
</view>
