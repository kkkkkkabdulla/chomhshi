.detail-header-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.detail-title {
  font-weight: 800;
  font-size: 38rpx;
  margin-bottom: 18rpx;
  color: #1a1d2e;
  line-height: 1.4;
}

.detail-warning {
  margin-bottom: 14rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-weight: 600;
  font-size: 26rpx;
}

.detail-warning-orange {
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  color: #ad6800;
}

.detail-warning-red {
  background: #fff1f2;
  border: 1rpx solid #fecdd3;
  color: #cf1322;
}

.detail-warning-yellow {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  color: #ad8b00;
}

.detail-desc-box {
  background: linear-gradient(135deg, #f5f7ff, #f8f9fd);
  border: 1rpx solid #e0e7ff;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 18rpx;
}

.detail-desc-label {
  font-size: 24rpx;
  color: #4f6ef7;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.detail-desc-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #374151;
  white-space: pre-wrap;
}

.detail-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.detail-meta-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.detail-images {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.detail-img {
  width: 30%;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f2f4f9;
}

.detail-action-bar {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.detail-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 18rpx;
  border-radius: 16rpx;
  background: #f4f6fb;
  font-size: 22rpx;
  color: #6b7280;
  font-weight: 500;
}

.detail-action-liked {
  background: #fff1f2;
  color: #e8364e;
}

.detail-action-collected {
  background: #fffbeb;
  color: #d97706;
}

.heart-icon {
  width: 48rpx;
  height: 48rpx;
}

.animate-liked {
  animation: heart-bounce 0.42s ease;
}

@keyframes heart-bounce {
  0% {
    transform: scale(0.3);
  }
  45% {
    transform: scale(1.25);
  }
  100% {
    transform: scale(1);
  }
}

.detail-report-btn {
  margin-left: auto;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f4f6fb;
  color: #8b93a7;
  font-size: 24rpx;
  font-weight: 500;
}

.detail-comment-input {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.comment-input-wrap {
  display: flex;
  align-items: center;
  background: #f4f6fb;
  border: 2rpx solid #e8ecf4;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 80rpx;
  box-sizing: border-box;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: #1a1d2e;
  background: transparent;
  border: none;
  margin-bottom: 0;
  padding: 0;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2f4f9;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f2f4f9;
  flex-shrink: 0;
  border: 2rpx solid #e8ecf4;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.comment-nickname {
  font-weight: 600;
  font-size: 28rpx;
  color: #1a1d2e;
}

.comment-id {
  font-size: 20rpx;
}

.comment-content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
}

.comment-time {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8b93a7;
}

.loading-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 28rpx;
  text-align: center;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e8ecf4;
  border-top-color: #4f6ef7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  color: #8b93a7;
  font-size: 28rpx;
}
