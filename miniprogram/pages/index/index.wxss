.notice-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}
.notice-modal {
  width: 100%;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border-radius: 28rpx;
  padding: 30rpx;
  box-sizing: border-box;
  max-height: 84vh;
  overflow: auto;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,.18);
  border: 1rpx solid #d7e7ff;
}
.notice-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid #e8eef8;
}
.notice-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #f3f5f7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #4e5969;
  flex-shrink: 0;
}
.notice-time {
  margin-top: 12rpx;
  color: #8b93a7;
  font-size: 24rpx;
}
.notice-content {
  margin-top: 18rpx;
  line-height: 1.85;
  white-space: pre-wrap;
  color: #2c3e50;
  font-size: 28rpx;
  padding: 4rpx 2rpx 2rpx;
}
