.publish-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.required-star {
  color: #e8364e;
  margin-right: 4rpx;
  font-weight: 700;
}

.publish-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1d2e;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

.category-section {
  margin-bottom: 20rpx;
}

.category-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1d2e;
  margin-bottom: 14rpx;
}

.category-pills {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.category-pill {
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  border: 2rpx solid #e8ecf4;
  background: #f8f9fd;
  font-size: 26rpx;
  font-weight: 600;
  color: #6b7280;
  transition: all 0.2s;
}

.category-pill-active {
  background: linear-gradient(135deg, #4f6ef7, #7c5cfc);
  border-color: transparent;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(79, 110, 247, 0.3);
  transform: translateY(-2rpx);
}

.publish-input {
  margin-bottom: 18rpx;
}

.desc-section {
  margin-bottom: 18rpx;
}

.desc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.desc-label {
  font-size: 24rpx;
  color: #4f6ef7;
  font-weight: 700;
}

.publish-textarea {
  min-height: 260rpx;
  line-height: 1.7;
  font-size: 28rpx;
  background: #f8f9fd;
  border: 2rpx solid #e8ecf4;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  margin-bottom: 0;
}

.price-hint {
  padding: 10rpx 0 18rpx;
  font-size: 24rpx;
}

.upload-section {
  margin-bottom: 24rpx;
}

.upload-header {
  margin-bottom: 16rpx;
}

.upload-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1d2e;
}

.upload-count {
  font-size: 24rpx;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.upload-preview {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.upload-preview-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  background: #f2f4f9;
}

.upload-remove {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(232, 54, 78, 0.85);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
  box-shadow: 0 4rpx 8rpx rgba(232, 54, 78, 0.3);
}

.upload-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #c9cdd4;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #f8f9fd;
}

.upload-add-text {
  font-size: 20rpx;
  color: #8b93a7;
}

.publish-btn {
  width: 100%;
  height: 96rpx;
  line-height: 62rpx;
  font-size: 32rpx;
  border-radius: 18rpx;
  margin-top: 8rpx;
}
