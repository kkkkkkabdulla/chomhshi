<view class="card">
  <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
    <view class="card">分类：{{category}}</view>
  </picker>
  <input placeholder="标题（必填）" value="{{title}}" bindinput="onInputTitle" class="card" />
  <textarea placeholder="描述（必填）" value="{{desc}}" bindinput="onInputDesc" class="card" />
  <input wx:if="category==='二手交易'" placeholder="价格（元）" type="number" value="{{price}}" bindinput="onInputPrice" class="card" />
  <view style="margin:16rpx 0">
    <button type="primary" bindtap="chooseImage">选择图片</button>
    <scroll-view scroll-x style="white-space:nowrap;margin-top:8rpx">
      <image wx:for="{{images}}" wx:key="index" src="{{item}}" style="width:120rpx;height:120rpx;display:inline-block;margin-right:8rpx;border-radius:8rpx" />
    </scroll-view>
  </view>
  <button class="btn-primary" bindtap="onSubmit">发布</button>
</view>
