<view class="container">
  <view wx:if="{{noticePopupVisible}}" class="notice-mask" bindtap="closeNoticePopup">
    <view class="notice-modal" catchtap="noop">
      <view style="display:flex;align-items:center;justify-content:space-between;gap:16rpx;margin-bottom:18rpx;">
        <view>
          <view style="font-size:22rpx;color:#1677ff;font-weight:800;letter-spacing:2rpx;">系统通知</view>
          <view style="font-size:36rpx;font-weight:900;color:#1f2d3d;line-height:1.2;margin-top:6rpx;">公告</view>
        </view>
        <view class="notice-close" bindtap="closeNoticePopup">×</view>
      </view>
      <view class="notice-head">
        <view style="display:flex;align-items:center;gap:12rpx;min-width:0;">
          <view wx:if="{{noticePopup.isLatest}}" style="padding:4rpx 10rpx;border-radius:999rpx;background:#1677ff;color:#fff;font-size:22rpx;font-weight:700;flex-shrink:0;">最新</view>
          <view style="font-size:32rpx;font-weight:800;color:#1f2d3d;line-height:1.4;" class="text-ellipsis">{{noticePopup.title}}</view>
        </view>
      </view>
      <view class="notice-time">{{noticePopup.createdAtText}}</view>
      <view class="notice-content" style="max-height:520rpx;overflow:auto;">{{noticePopup.content}}</view>
      <button class="btn-primary" style="margin-top:16rpx;" bindtap="closeNoticePopup">我知道了</button>
    </view>
  </view>

  <view class="card" style="padding-bottom:16rpx;">
    <view class="section-title">信息广场</view>

    <view style="display:flex;gap:14rpx;align-items:center;margin-bottom:12rpx;">
      <view class="icon-text" style="flex:1;background:#f4f7ff;padding:12rpx 14rpx;border-radius:12rpx;">
        <image class="icon-sm" src="/assets/icons/search.svg" mode="aspectFit" />
        <input class="input" style="flex:1;margin-bottom:0;border:none;background:transparent;padding:0;" placeholder="搜索" value="{{keyword}}" bindinput="onKeywordInput" />
      </view>
      <button size="mini" class="btn-primary" bindtap="onSearch">搜索</button>
    </view>

    <view class="row" style="font-size:30rpx;color:#344054;line-height:1.8;gap:22rpx;flex-wrap:wrap;margin-top:2rpx;">
      <text data-tab="second" bindtap="onTabClick" style="{{activeTab==='second' ? 'color:#1677ff;font-weight:700;' : ''}}">二手</text>
      <text>｜</text>
      <text data-tab="lost" bindtap="onTabClick" style="{{activeTab==='lost' ? 'color:#1677ff;font-weight:700;' : ''}}">失物</text>
      <text>｜</text>
      <text data-tab="free" bindtap="onTabClick" style="{{activeTab==='free' ? 'color:#1677ff;font-weight:700;' : ''}}">随心贴</text>
      <text>｜</text>
      <text data-tab="help" bindtap="onTabClick" style="{{activeTab==='help' ? 'color:#1677ff;font-weight:700;' : ''}}">互助</text>
      <text>｜</text>
      <text data-tab="notice" bindtap="onTabClick" style="{{activeTab==='notice' ? 'color:#1677ff;font-weight:700;' : ''}}">公告</text>
    </view>

    <view style="height:1rpx;background:#eceef2;margin:14rpx 0 2rpx;"></view>
  </view>

  <view wx:if="{{activeTab === 'notice' && noticeList.length}}" class="card" style="padding:18rpx;">
    <view style="margin-bottom:18rpx;">
      <view style="font-size:22rpx;color:#1677ff;font-weight:800;letter-spacing:2rpx;">系统通知</view>
      <view style="font-size:34rpx;font-weight:900;color:#1f2d3d;line-height:1.2;margin-top:4rpx;">公告</view>
    </view>
    <view wx:for="{{noticeList}}" wx:key="id" style="padding:14rpx 0;border-bottom:1rpx solid #f2f3f5;{{item.isLatest ? 'background:#f0f7ff;border-radius:12rpx;padding:16rpx;border:1rpx solid #cfe3ff;margin-bottom:12rpx;' : ''}}" bindtap="goNoticeDetail" data-id="{{item.id}}">
      <view class="row-between" style="margin-bottom:8rpx;gap:10rpx;">
        <view style="display:flex;align-items:center;gap:10rpx;min-width:0;">
          <view wx:if="{{item.isLatest}}" style="padding:4rpx 10rpx;border-radius:999rpx;background:#1677ff;color:#fff;font-size:22rpx;font-weight:700;flex-shrink:0;">最新</view>
          <view style="font-weight:700;font-size:28rpx;max-width:420rpx;" class="text-ellipsis">{{item.title}}</view>
        </view>
        <view class="muted">{{item.createdAtText}} · {{item.createdByText}}</view>
      </view>
      <view class="muted" style="line-height:1.6;{{item.isLatest ? 'font-weight:600;color:#1f2d3d;' : ''}}">{{item.content}}</view>
    </view>
  </view>

  <view wx:for="{{list}}" wx:key="id" class="card" bindtap="goDetail" data-id="{{item.id}}" style="padding:18rpx;">
    <view style="display:flex;gap:14rpx;">
      <image src="{{item.imageList[0] || 'https://via.placeholder.com/220x220.png?text=Post'}}" mode="aspectFill" style="width:176rpx;height:176rpx;border-radius:14rpx;background:#f2f3f5;flex-shrink:0;" />

      <view style="flex:1;min-width:0;">
        <view class="row-between" style="margin-bottom:8rpx;">
          <view class="tag">{{item.type === 1 ? '失物招领' : '二手物品'}}</view>
          <view wx:if="{{item.price !== null && item.price !== undefined}}" style="font-size:22rpx;background:#fff7e8;color:#ff7d00;border-radius:999rpx;padding:4rpx 10rpx;">￥{{item.price}}</view>
        </view>

        <view class="text-ellipsis" style="font-size:30rpx;font-weight:700;margin-bottom:8rpx;">{{item.title}}</view>
        <view style="line-height:1.6;color:#4e5969;font-size:26rpx;margin-top:2rpx;">{{item.summary}}</view>
      </view>
    </view>

    <view wx:if="{{item.imageList.length > 1}}" style="display:flex;gap:10rpx;margin-top:12rpx;">
      <image wx:for="{{item.imageList}}" wx:key="index" wx:if="{{index > 0}}" src="{{item}}" mode="aspectFill" style="flex:1;height:132rpx;border-radius:10rpx;background:#f2f3f5;" />
    </view>

    <view style="display:flex;gap:18rpx;align-items:center;margin-top:12rpx;" class="muted">
      <view class="icon-text" catchtap="onToggleLike" data-id="{{item.id}}" style="padding:6rpx 10rpx;border-radius:999rpx;background:{{item.liked ? '#fff1f0' : '#f5f7fa'}};opacity:{{item.liking ? 0.6 : 1}};">
        <image class="icon-lg" src="{{item.liked ? '/assets/icons/like-filled.svg' : '/assets/icons/like.svg'}}" mode="aspectFit" />
        <text style="color:{{item.liked ? '#ff4d4f' : '#667085'}};">{{item.likeCount}}</text>
      </view>
      <view class="icon-text">
        <image class="icon-lg" src="/assets/icons/comment.svg" mode="aspectFit" />
        <text>{{item.commentCount}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!list.length}}" class="muted" style="text-align:center;padding:64rpx 0;">暂无数据，试试更换关键词</view>
</view>
