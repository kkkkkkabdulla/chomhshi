page {
  background: #f2f4f9;
  color: #1a1d2e;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
  color: #1a1d2e;
  letter-spacing: 0.5rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #4f6ef7, #7c5cfc);
  color: #fff;
  border-radius: 16rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 24rpx rgba(79, 110, 247, 0.3);
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-danger {
  background: #fff1f2;
  color: #e8364e;
  border: 1rpx solid #fecdd3;
  border-radius: 16rpx;
  font-weight: 600;
}

.btn-danger::after {
  border: none;
}

.input {
  border: 2rpx solid #e8ecf4;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 18rpx;
  background: #f8f9fd;
  font-size: 28rpx;
  color: #1a1d2e;
  transition: all 0.2s;
}

.input-focus {
  border-color: #4f6ef7;
  background: #fff;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.icon-text {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.icon-xs {
  width: 28rpx;
  height: 28rpx;
}

.icon-sm {
  width: 32rpx;
  height: 32rpx;
}

.icon-lg {
  width: 48rpx;
  height: 48rpx;
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  color: #4f6ef7;
  background: #eef1ff;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.muted {
  color: #8b93a7;
  font-size: 24rpx;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #e8ecf4, transparent);
  margin: 18rpx 0;
}

.price-tag {
  font-size: 22rpx;
  background: linear-gradient(135deg, #fff7e6, #fff1d6);
  color: #e8830c;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  font-weight: 700;
  border: 1rpx solid #ffe0b2;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-pending {
  background: #fffbe6;
  color: #d48806;
  border: 1rpx solid #ffe58f;
}

.status-offline {
  background: #fff1f0;
  color: #cf1322;
  border: 1rpx solid #ffccc7;
}

.status-online {
  background: #f6ffed;
  color: #389e0d;
  border: 1rpx solid #b7eb8f;
}
