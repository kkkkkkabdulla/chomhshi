<view class="container">
  <view wx:if="{{noticePopupVisible}}" class="notice-mask" bindtap="closeNoticePopup">
    <view class="notice-modal" catchtap="noop">
      <view class="notice-modal-header">
        <view class="notice-modal-title-group">
          <view class="notice-modal-badge">系统通知</view>
          <view class="notice-modal-heading">公告</view>
        </view>
        <view class="notice-close" bindtap="closeNoticePopup">×</view>
      </view>
      <view class="notice-modal-body">
        <view class="notice-modal-item-header">
          <view wx:if="{{noticePopup.isLatest}}" class="notice-latest-tag">最新</view>
          <view class="notice-modal-item-title text-ellipsis">{{noticePopup.title}}</view>
        </view>
        <view class="notice-modal-time">{{noticePopup.createdAtText}}</view>
        <view class="notice-modal-content">{{noticePopup.content}}</view>
      </view>
      <button class="btn-primary notice-modal-btn" bindtap="closeNoticePopup">我知道了</button>
    </view>
  </view>

  <view class="search-card">
    <view class="search-title-row">
      <view class="search-title">信息广场</view>
      <view class="search-title-dot"></view>
    </view>

    <view class="search-bar">
      <view class="search-input-wrap">
        <image class="search-icon" src="/assets/icons/search.svg" mode="aspectFit" />
        <input class="search-input" placeholder="搜索你感兴趣的内容..." value="{{keyword}}" bindinput="onKeywordInput" />
      </view>
      <button size="mini" class="btn-primary search-btn" bindtap="onSearch">搜索</button>
    </view>

    <view class="tab-row">
      <view class="tab-item {{activeTab==='second' ? 'tab-active' : ''}}" data-tab="second" bindtap="onTabClick">
        <text>二手交易</text>
      </view>
      <view class="tab-divider"></view>
      <view class="tab-item {{activeTab==='lost' ? 'tab-active' : ''}}" data-tab="lost" bindtap="onTabClick">
        <text>失物招领</text>
      </view>
      <view class="tab-divider"></view>
      <view class="tab-item {{activeTab==='help' ? 'tab-active' : ''}}" data-tab="help" bindtap="onTabClick">
        <text>求助</text>
      </view>
      <view class="tab-divider"></view>
      <view class="tab-item {{activeTab==='free' ? 'tab-active' : ''}}" data-tab="free" bindtap="onTabClick">
        <text>自由动态</text>
      </view>
      <view class="tab-divider"></view>
      <view class="tab-item {{activeTab==='notice' ? 'tab-active' : ''}}" data-tab="notice" bindtap="onTabClick">
        <text>公告</text>
      </view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'notice' && noticeList.length}}" class="card notice-card">
    <view class="notice-section-header">
      <view class="notice-section-badge">系统通知</view>
      <view class="notice-section-heading">公告</view>
    </view>
    <view wx:for="{{noticeList}}" wx:key="id" class="notice-item {{item.isLatest ? 'notice-item-latest' : ''}}" bindtap="goNoticeDetail" data-id="{{item.id}}">
      <view class="notice-item-header">
        <view class="notice-item-title-row">
          <view wx:if="{{item.isLatest}}" class="notice-latest-tag">最新</view>
          <view class="notice-item-title text-ellipsis">{{item.title}}</view>
        </view>
        <view class="notice-item-meta">{{item.createdAtText}} · {{item.createdByText}}</view>
      </view>
      <view class="notice-item-content muted">{{item.content}}</view>
    </view>
  </view>

  <view wx:for="{{list}}" wx:key="id" class="post-card" bindtap="goDetail" data-id="{{item.id}}">
    <view class="post-main">
      <view class="post-head-line">
        <view class="post-cat-tag">{{item.categoryLabel}}</view>
        <view wx:if="{{item.price !== null && item.price !== undefined}}" class="post-price-tag">￥{{item.price}}</view>
      </view>

      <view class="post-title text-ellipsis">{{item.title}}</view>
      <view class="post-desc">{{item.summary}}</view>

      <view class="post-foot-line">
        <view class="post-action {{item.liked ? 'action-like' : ''}}" catchtap="onToggleLike" data-id="{{item.id}}">
          <image class="action-icon" src="{{item.liked ? '/assets/icons/like-filled.svg' : '/assets/icons/like.svg'}}" mode="aspectFit" />
          <text>{{item.likeCount || 0}}</text>
        </view>
        <view class="post-action {{item.collected ? 'action-collect' : ''}}" catchtap="onToggleCollect" data-id="{{item.id}}">
          <image class="action-icon" src="{{item.collected ? '/assets/icons/collect-filled.svg' : '/assets/icons/collect.svg'}}" mode="aspectFit" />
          <text>{{item.collectCount || 0}}</text>
        </view>
        <view class="post-action">
          <image class="action-icon" src="/assets/icons/comment.svg" mode="aspectFit" />
          <text>{{item.commentCount || 0}}</text>
        </view>
      </view>
    </view>

    <image wx:if="{{item.imageList && item.imageList.length}}" src="{{item.imageList[0]}}" mode="aspectFill" class="post-thumb-img" />
  </view>

  <view wx:if="{{activeTab !== 'notice' && !list.length}}" class="empty-state">
    <view class="empty-icon">📭</view>
    <view class="empty-text">暂无数据</view>
    <view class="empty-hint">试试更换关键词或切换分类</view>
  </view>

  <view wx:if="{{activeTab !== 'notice' && list.length}}" class="load-more-tip">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{noMore}}">— 已经到底了 —</text>
  </view>
</view>
