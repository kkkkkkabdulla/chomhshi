<view class="container">
  <view class="publish-card">
    <view class="publish-title">发布动态</view>

    <view class="category-section">
      <view class="category-label"><text class="required-star">*</text>选择分类</view>
      <view class="category-pills">
        <view
          wx:for="{{categoryTabs}}"
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="onCategorySelect"
          class="category-pill {{activeCategory === item.value ? 'category-pill-active' : ''}}"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="divider"></view>

    <input class="input publish-input" placeholder="输入标题（必填）" maxlength="200" value="{{form.title}}" data-key="title" bindinput="onInput" />

    <view class="desc-section">
      <view class="desc-header">
        <view class="desc-label"><text class="required-star">*</text>描述内容</view>
        <view class="desc-count muted">{{form.description.length || 0}} / 2000</view>
      </view>
      <textarea
        class="input publish-textarea"
        maxlength="2000"
        placeholder="{{currentType === 1 ? '请描述物品特征、丢失/拾到经过等' : currentType === 2 ? '请描述物品成色、购买时间、转让原因等' : currentType === 4 ? '请描述你遇到的困难或需要的帮助' : '分享你的校园生活动态...'}}"
        value="{{form.description}}"
        data-key="description"
        bindinput="onInput"
      />
    </view>

    <view wx:if="{{currentType === 1}}">
      <input class="input publish-input" placeholder="丢失/拾到地点（选填）" maxlength="100" value="{{form.location}}" data-key="location" bindinput="onInput" />
    </view>

    <view wx:if="{{currentType === 2}}">
      <input class="input publish-input" placeholder="价格（元，必填）" value="{{form.price}}" data-key="price" bindinput="onInput" type="digit" />
    </view>

    <view wx:if="{{currentType === 1 || currentType === 2 || currentType === 4}}">
      <input class="input publish-input" placeholder="联系方式（微信/手机号，必填）" value="{{form.contact}}" data-key="contact" bindinput="onInput" />
    </view>

    <view class="divider"></view>

    <view class="upload-section">
      <view class="upload-header row-between">
        <view class="upload-label">图片</view>
        <view class="upload-count muted">已上传 {{imageUrls.length}} / 6 张</view>
      </view>

      <view class="upload-grid">
        <view wx:for="{{imageUrls}}" wx:key="index" class="upload-preview">
          <image src="{{item}}" mode="aspectFill" class="upload-preview-img" bindtap="previewImage" data-index="{{index}}" />
          <view bindtap="removeImage" data-index="{{index}}" class="upload-remove">×</view>
        </view>
        <view wx:if="{{imageUrls.length < 6}}" class="upload-add" bindtap="chooseImages">
          <image class="icon-lg" src="/assets/icons/upload.svg" mode="aspectFit" />
          <text class="upload-add-text">添加图片</text>
        </view>
      </view>
    </view>

    <button class="btn-primary publish-btn" bindtap="submit" loading="{{loading}}" disabled="{{loading}}" style="position: relative; left: 2rpx; top: 2rpx">立即发布</button>
  </view>
</view>
