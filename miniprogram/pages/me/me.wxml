<view class="container">
  <view class="card">
    <view class="section-title">我的资料</view>

    <view wx:if="{{!editingProfile}}" class="row" style="gap:16rpx;align-items:center;margin-bottom:16rpx;">
      <image src="{{user.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" style="width:96rpx;height:96rpx;border-radius:50%;background:#f2f3f5;border:2rpx solid #e6eefc;" />
      <view style="flex:1;">
        <view style="font-size:30rpx;font-weight:700;">{{user.nickname || '未设置昵称'}}</view>
        <view class="muted" style="margin-top:4rpx;">{{user.phone || '未绑定手机号'}}</view>
      </view>
      <button size="mini" bindtap="startEditProfile">编辑</button>
    </view>

    <view wx:if="{{editingProfile}}" style="display:flex;flex-direction:column;gap:14rpx;">
      <view class="row" style="gap:16rpx;align-items:center;">
        <image src="{{profileForm.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" style="width:96rpx;height:96rpx;border-radius:50%;background:#f2f3f5;border:2rpx solid #e6eefc;" />
        <button size="mini" bindtap="chooseAvatar">更换头像</button>
      </view>
      <input class="input" placeholder="昵称" value="{{profileForm.nickname}}" data-key="nickname" bindinput="onProfileInput" />
      <input class="input" placeholder="手机号" value="{{profileForm.phone}}" data-key="phone" bindinput="onProfileInput" maxlength="11" type="number" />
      <view class="row" style="gap:12rpx;">
        <button class="btn-primary" bindtap="saveProfile">保存</button>
        <button bindtap="cancelEditProfile">取消</button>
      </view>
    </view>

    <view class="row-between" style="margin-top:14rpx;">
      <view class="muted">用户ID</view>
      <view>{{user.id || '-'}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">我的发布</view>
    <view wx:for="{{myPosts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}" style="padding: 16rpx 0; border-bottom: 1rpx solid #f2f3f5;">
      <view class="row-between" style="margin-bottom:8rpx;">
        <view style="font-weight:600;max-width:68%;" class="text-ellipsis">{{item.title}}</view>
        <view
          class="tag"
          style="{{item.status === 3 ? 'background:#fff1f0;color:#cf1322;border:1rpx solid #ffccc7;' : item.status === 0 ? 'background:#fffbe6;color:#ad6800;border:1rpx solid #ffe58f;' : 'background:#f6ffed;color:#389e0d;border:1rpx solid #b7eb8f;'}}"
        >
          {{item.status === 3 ? '已下架' : item.status === 1 ? '已发布' : item.status === 0 ? '待审核' : item.status}}
        </view>
      </view>
      <view class="muted" style="margin-bottom:10rpx;">{{item.description || '暂无描述'}}</view>
      <view class="row" style="gap:12rpx;">
        <button size="mini" class="btn-danger" data-id="{{item.id}}" catchtap="onDeletePost">删除</button>
      </view>
    </view>
    <view wx:if="{{!myPosts.length}}" class="muted" style="text-align:center;padding:18rpx 0;">暂无发布记录</view>
  </view>

  <button bindtap="onLogout" class="btn-danger">退出登录</button>
</view>
