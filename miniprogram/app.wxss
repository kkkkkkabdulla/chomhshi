page {
  background: #f6f8fc;
  color: #1f2329;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #1677ff, #3f8cff);
  color: #fff;
  border-radius: 12rpx;
}

.btn-danger {
  background: #fff2f0;
  color: #f53f3f;
  border: 1rpx solid #ffccc7;
  border-radius: 12rpx;
}

.input {
  border: 1rpx solid #e5e6eb;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  background: #fff;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.icon-text {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.icon-xs {
  width: 28rpx;
  height: 28rpx;
}

.icon-sm {
  width: 32rpx;
  height: 32rpx;
}

.icon-lg {
  width: 56rpx;
  height: 56rpx;
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  color: #1677ff;
  background: #e8f3ff;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.muted {
  color: #86909c;
  font-size: 24rpx;
}
