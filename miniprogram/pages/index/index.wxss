.notice-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(26, 29, 46, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.notice-modal {
  width: 100%;
  background: #fff;
  border-radius: 32rpx;
  padding: 36rpx;
  box-sizing: border-box;
  max-height: 84vh;
  overflow: auto;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.2);
}

.notice-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.notice-modal-title-group {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.notice-modal-badge {
  font-size: 22rpx;
  color: #4f6ef7;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.notice-modal-heading {
  font-size: 38rpx;
  font-weight: 900;
  color: #1a1d2e;
}

.notice-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f4f6fb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #6b7280;
}

.notice-modal-body {
  padding: 20rpx;
  background: #f8f9fd;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.notice-modal-item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.notice-modal-item-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1a1d2e;
}

.notice-modal-time {
  color: #8b93a7;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.notice-modal-content {
  line-height: 1.85;
  white-space: pre-wrap;
  color: #374151;
  font-size: 28rpx;
}

.notice-modal-btn {
  margin-top: 8rpx;
  border-radius: 18rpx;
}

.notice-latest-tag {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f6ef7, #7c5cfc);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.search-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.search-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.search-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1d2e;
  letter-spacing: 1rpx;
}

.search-title-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4f6ef7, #7c5cfc);
}

.search-bar {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f4f6fb;
  border: 2rpx solid #e8ecf4;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 80rpx;
  box-sizing: border-box;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: #1a1d2e;
  background: transparent;
  border: none;
  margin-bottom: 0;
  padding: 0;
}

.search-btn {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  border-radius: 16rpx;
}

.tab-row {
  display: flex;
  align-items: center;
  gap: 0;
  background: #f4f6fb;
  border-radius: 16rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #6b7280;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-active {
  background: #fff;
  color: #4f6ef7;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(79, 110, 247, 0.12);
}

.tab-divider {
  width: 1rpx;
  height: 24rpx;
  background: #d1d5db;
  flex-shrink: 0;
}

.notice-card {
  padding: 28rpx;
}

.notice-section-header {
  margin-bottom: 20rpx;
}

.notice-section-badge {
  font-size: 22rpx;
  color: #4f6ef7;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.notice-section-heading {
  font-size: 34rpx;
  font-weight: 900;
  color: #1a1d2e;
  margin-top: 4rpx;
}

.notice-item {
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  border-bottom: 1rpx solid #f2f4f9;
}

.notice-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.notice-item-latest {
  background: linear-gradient(135deg, #eef1ff, #f5f3ff);
  border: 1rpx solid #d4d9ff;
  border-bottom: none;
}

.notice-item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.notice-item-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.notice-item-title {
  font-weight: 700;
  font-size: 28rpx;
  max-width: 400rpx;
}

.notice-item-meta {
  font-size: 22rpx;
  color: #8b93a7;
  flex-shrink: 0;
}

.notice-item-content {
  line-height: 1.6;
}

.post-card {
  padding: 24rpx;
  transition: transform 0.15s;
}

.post-card-with-img {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.post-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 18rpx;
  background: #f2f4f9;
  flex-shrink: 0;
}

.post-body {
  flex: 1;
  min-width: 0;
}

.post-card-no-img {
  padding: 4rpx 0;
}

.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
  gap: 12rpx;
}

.post-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1d2e;
  margin-bottom: 8rpx;
}

.post-summary {
  line-height: 1.6;
  color: #6b7280;
  font-size: 26rpx;
}

.post-no-img-hint {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f6fb;
  color: #8b93a7;
  font-size: 22rpx;
  margin-top: 12rpx;
}

.post-extra-images {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.post-extra-img {
  flex: 1;
  height: 140rpx;
  border-radius: 14rpx;
  background: #f2f4f9;
}

.post-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f2f4f9;
}

.post-action-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f4f6fb;
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

.post-action-liked {
  background: #fff1f2;
  color: #e8364e;
}

.post-action-collected {
  background: #fffbeb;
  color: #d97706;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8b93a7;
}
