.profile-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.profile-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.profile-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #f2f4f9;
  border: 3rpx solid #e0e7ff;
  flex-shrink: 0;
}

.profile-text {
  flex: 1;
  min-width: 0;
}

.profile-nickname {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1d2e;
  margin-bottom: 4rpx;
}

.profile-phone {
  font-size: 24rpx;
}

.profile-edit-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f4f6fb;
  color: #4f6ef7;
  font-size: 24rpx;
  font-weight: 600;
}

.profile-edit-form {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.profile-edit-avatar-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-change-avatar-btn {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f6ef7, #7c5cfc);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.profile-edit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.profile-save-btn {
  flex: 1;
}

.profile-cancel-btn {
  flex: 1;
  background: #f4f6fb;
  color: #6b7280;
  border-radius: 16rpx;
  font-weight: 600;
  border: none;
}

.profile-cancel-btn::after {
  border: none;
}

.profile-id-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f2f4f9;
}

.profile-id-value {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
}

.tabs-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(79, 110, 247, 0.06), 0 0 1rpx rgba(79, 110, 247, 0.08);
}

.tabs-header {
  display: flex;
  gap: 0;
  margin-bottom: 20rpx;
  background: #f4f6fb;
  border-radius: 16rpx;
  padding: 6rpx;
  overflow: hidden;
}

.tab-switch {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7280;
  transition: all 0.2s;
}

.tab-switch-active {
  background: #fff;
  color: #4f6ef7;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(79, 110, 247, 0.12);
}

.tab-count {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: #e8ecf4;
  color: #6b7280;
}

.tab-switch-active .tab-count {
  background: #eef1ff;
  color: #4f6ef7;
}

.collect-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  display: flex;
  gap: 0;
  box-shadow: 0 2rpx 12rpx rgba(79, 110, 247, 0.05), 0 0 1rpx rgba(79, 110, 247, 0.06);
}

.collect-main {
  flex: 1;
  padding: 20rpx 18rpx 16rpx 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.collect-thumb-img {
  width: 200rpx;
  min-height: 180rpx;
  max-height: 240rpx;
  flex-shrink: 0;
  object-fit: cover;
  border-radius: 0 20rpx 20rpx 0;
}

.collect-head-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.collect-cat-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f6ef7, #7c5cfc);
  color: #fff;
  font-weight: 700;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.collect-star-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
  color: #d97706;
  font-weight: 700;
  border: 1rpx solid #fde68a;
  flex-shrink: 0;
}

.collect-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1d2e;
  line-height: 1.35;
  margin-bottom: 6rpx;
}

.collect-desc {
  line-height: 1.5;
  color: #6b7280;
  font-size: 24rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.collect-tags-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.collect-tag-pill {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #f0f2ff;
  color: #7c5cfc;
  font-weight: 500;
  border: 1rpx solid #e0e4ff;
}

.mypost-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  display: flex;
  gap: 0;
  box-shadow: 0 2rpx 12rpx rgba(79, 110, 247, 0.05), 0 0 1rpx rgba(79, 110, 247, 0.06);
}

.mypost-main {
  flex: 1;
  padding: 20rpx 18rpx 16rpx 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.mypost-thumb-img {
  width: 200rpx;
  min-height: 180rpx;
  max-height: 240rpx;
  flex-shrink: 0;
  object-fit: cover;
  border-radius: 0 20rpx 20rpx 0;
}

.mypost-head-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.mypost-cat-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f6ef7, #7c5cfc);
  color: #fff;
  font-weight: 700;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.mypost-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1d2e;
  line-height: 1.35;
  margin-bottom: 6rpx;
}

.mypost-desc {
  line-height: 1.5;
  color: #6b7280;
  font-size: 24rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.mypost-tags-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.mypost-tag-pill {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #f0f2ff;
  color: #7c5cfc;
  font-weight: 500;
  border: 1rpx solid #e0e4ff;
}

.mypost-foot-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f2f4f9;
}

.post-delete-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1f2;
  color: #e8364e;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #fecdd3;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7280;
}

.blocked-banner {
  background: #fff1f0;
  color: #cf1322;
  border: 1rpx solid #ffccc7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

.status-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 700;
}

.status-pending {
  background: #fffbe6;
  color: #d48806;
  border: 1rpx solid #ffe58f;
}

.status-rejected {
  background: #fff1f2;
  color: #cf1322;
  border: 1rpx solid #ffccc7;
}

.status-online {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}
