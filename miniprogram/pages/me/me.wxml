<view class="container">
  <view class="card">
    <view class="section-title">我的资料</view>

    <view class="row" style="gap:16rpx;align-items:center;margin-bottom:16rpx;">
      <image src="{{user.avatarUrl || 'https://via.placeholder.com/120x120.png?text=User'}}" mode="aspectFill" style="width:96rpx;height:96rpx;border-radius:50%;background:#f2f3f5;" />
      <view>
        <view style="font-size:30rpx;font-weight:700;">{{user.nickname || '未设置昵称'}}</view>
        <view class="muted" style="margin-top:4rpx;">{{user.phone || '未绑定手机号'}}</view>
      </view>
    </view>

    <view class="row-between">
      <view class="muted">用户ID</view>
      <view>{{user.id || '-'}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">我的发布</view>
    <view wx:for="{{myPosts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}" style="padding: 16rpx 0; border-bottom: 1rpx solid #f2f3f5;">
      <view class="row-between" style="margin-bottom:8rpx;">
        <view style="font-weight:600;max-width:68%;" class="text-ellipsis">{{item.title}}</view>
        <view class="tag">状态: {{item.status}}</view>
      </view>
      <view class="muted" style="margin-bottom:10rpx;">{{item.description || '暂无描述'}}</view>
      <view class="row" style="gap:12rpx;">
        <button size="mini" class="btn-danger" data-id="{{item.id}}" catchtap="onDeletePost">删除</button>
      </view>
    </view>
    <view wx:if="{{!myPosts.length}}" class="muted" style="text-align:center;padding:18rpx 0;">暂无发布记录</view>
  </view>

  <button bindtap="onLogout" class="btn-danger">退出登录</button>
</view>
