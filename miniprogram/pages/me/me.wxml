<view class="container">
  <view class="profile-card">
    <view wx:if="{{!editingProfile}}" class="profile-info">
      <image src="{{user.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" class="profile-avatar" />
      <view class="profile-text">
        <view class="profile-nickname">{{user.nickname || '未设置昵称'}}</view>
        <view class="profile-phone muted">{{user.phone || '未绑定手机号'}}</view>
      </view>
      <view class="profile-edit-btn" bindtap="startEditProfile">
        <image class="icon-sm" src="/assets/icons/edit.svg" mode="aspectFit" />
        <text>编辑</text>
      </view>
    </view>

    <view wx:if="{{editingProfile}}" class="profile-edit-form">
      <view class="profile-edit-avatar-row">
        <image src="{{profileForm.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill" class="profile-avatar" />
        <view class="profile-change-avatar-btn" bindtap="chooseAvatar">更换头像</view>
      </view>
      <input class="input" placeholder="昵称" value="{{profileForm.nickname}}" data-key="nickname" bindinput="onProfileInput" />
      <input class="input" placeholder="手机号" value="{{profileForm.phone}}" data-key="phone" bindinput="onProfileInput" maxlength="11" type="number" />
      <view class="profile-edit-actions">
        <button class="btn-primary profile-save-btn" bindtap="saveProfile">保存</button>
        <button class="profile-cancel-btn" bindtap="cancelEditProfile">取消</button>
      </view>
    </view>

    <view class="profile-id-row">
      <view class="muted">用户ID</view>
      <view class="profile-id-value">{{user.id || '-'}}</view>
    </view>
  </view>

  <view class="tabs-card">
    <view class="tabs-header">
      <view class="tab-switch {{activeSection === 'collects' ? 'tab-switch-active' : ''}}" bindtap="switchSection" data-section="collects">
        <text>我的收藏</text>
        <view class="tab-count">{{myCollects.length}}</view>
      </view>
      <view class="tab-switch {{activeSection === 'posts' ? 'tab-switch-active' : ''}}" bindtap="switchSection" data-section="posts">
        <text>我的发布</text>
        <view class="tab-count">{{myPosts.length}}</view>
      </view>
    </view>

    <swiper current="{{activeSection === 'collects' ? 0 : 1}}" bindchange="onSectionSwipe" style="height:900rpx;">
      <swiper-item>
        <scroll-view scroll-y="true" style="height:900rpx;">
          <view wx:for="{{myCollects}}" wx:key="id" class="collect-item" bindtap="goCollectDetail" data-id="{{item.id}}">
            <view wx:if="{{item.imageList && item.imageList.length}}" class="collect-item-with-img">
              <image src="{{item.imageList[0]}}" mode="aspectFill" class="collect-cover" />
              <view class="collect-body">
                <view class="collect-item-header">
                  <view class="collect-item-title text-ellipsis">{{item.title}}</view>
                  <view class="collect-tag">已收藏</view>
                </view>
                <view class="collect-summary">{{item.summary}}</view>
                <view class="collect-category muted">{{item.category || '未分类'}}</view>
              </view>
            </view>
            <view wx:if="{{!item.imageList || !item.imageList.length}}" class="collect-item-no-img">
              <view class="collect-item-header">
                <view class="collect-item-title text-ellipsis">{{item.title}}</view>
                <view class="collect-tag">已收藏</view>
              </view>
              <view class="collect-summary">{{item.summary}}</view>
              <view class="collect-no-img-hint">暂无图片</view>
            </view>
          </view>
          <view wx:if="{{!myCollects.length}}" class="empty-state">
            <view class="empty-icon">⭐</view>
            <view class="empty-text">暂无收藏记录</view>
          </view>
        </scroll-view>
      </swiper-item>

      <swiper-item>
        <scroll-view scroll-y="true" style="height:900rpx;">
          <view wx:for="{{myPosts}}" wx:key="id" class="post-item" bindtap="goDetail" data-id="{{item.id}}">
            <view class="post-item-header">
              <view class="post-item-title text-ellipsis">{{item.title}}</view>
              <view class="status-badge {{item.status === 3 ? 'status-offline' : item.status === 0 ? 'status-pending' : 'status-online'}}">
                {{item.status === 3 ? '已下架' : item.status === 1 ? '已发布' : item.status === 0 ? '待审核' : item.status}}
              </view>
            </view>
            <view class="post-item-desc muted">{{item.description || '暂无描述'}}</view>
            <view class="post-item-actions">
              <view class="post-delete-btn" data-id="{{item.id}}" catchtap="onDeletePost">
                <image class="icon-xs" src="/assets/icons/delete.svg" mode="aspectFit" />
                <text>删除</text>
              </view>
            </view>
          </view>
          <view wx:if="{{!myPosts.length}}" class="empty-state">
            <view class="empty-icon">📝</view>
            <view class="empty-text">暂无发布记录</view>
          </view>
        </scroll-view>
      </swiper-item>
    </swiper>
  </view>

  <view class="logout-btn" bindtap="onLogout">退出登录</view>
</view>
