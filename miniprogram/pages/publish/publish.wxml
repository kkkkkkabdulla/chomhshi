<view class="container">
  <view class="card">
    <view class="section-title">发布动态</view>

    <view class="muted" style="margin-bottom:10rpx;">请选择分类（必选）</view>
    <view class="row" style="gap:14rpx;flex-wrap:wrap;margin-bottom:18rpx;">
      <view
        wx:for="{{categoryTabs}}"
        wx:key="value"
        class="tag"
        style="padding:10rpx 16rpx;font-size:26rpx;background:{{activeCategory === item.value ? '#e8f3ff' : '#f7f8fa'}};"
        data-value="{{item.value}}"
        bindtap="onCategorySelect"
      >
        <text style="color: {{activeCategory === item.value ? '#1677ff' : '#4e5969'}};font-weight:{{activeCategory === item.value ? '700' : '500'}};">{{item.label}}</text>
      </view>
    </view>

    <view class="muted" style="margin-bottom:10rpx;">当前发布类型：{{currentType === 2 ? '二手物品' : currentType === 1 ? '失物招领' : '通用帖子'}}</view>

    <input class="input" placeholder="标题" value="{{form.title}}" data-key="title" bindinput="onInput" />
    <view style="margin: 10rpx 0 14rpx; background:#f7fbff; border:1rpx solid #d9e8ff; border-radius:16rpx; padding:18rpx; box-shadow:0 6rpx 20rpx rgba(22,119,255,.06);">
      <view class="muted" style="margin-bottom:8rpx; font-size:24rpx; color:#1677ff; font-weight:600;">描述内容</view>
      <textarea class="input" style="min-height:220rpx; line-height:1.6; font-size:28rpx; background:#fff; border:1rpx solid #cfe0ff; border-radius:14rpx; padding:16rpx; box-sizing:border-box;" placeholder="请详细描述你的帖子内容，越清楚越容易被看到" value="{{form.description}}" data-key="description" bindinput="onInput" />
    </view>

    <view wx:if="{{currentType === 2}}">
      <input class="input" placeholder="价格（元）" value="{{form.price}}" data-key="price" bindinput="onInput" />
    </view>
    <view wx:if="{{currentType !== 2}}">
      <view class="muted" style="margin: 10rpx 0 12rpx;">当前类型不需要填写价格</view>
    </view>

    <input class="input" placeholder="联系方式（微信/手机号）" value="{{form.contact}}" data-key="contact" bindinput="onInput" />

    <view class="row-between" style="margin:8rpx 0 12rpx;">
      <view class="muted">图片（最多6张）</view>
      <view class="muted">已上传 {{imageUrls.length}} 张</view>
    </view>

    <view bindtap="chooseImages" style="border:2rpx dashed #c9cdd4;border-radius:12rpx;padding:20rpx;display:flex;align-items:center;justify-content:center;background:#fafcff;margin-bottom:12rpx;">
      <image class="icon-sm" src="/assets/icons/upload.svg" mode="aspectFit" />
    </view>

    <view wx:if="{{imageUrls.length}}" style="display:flex;flex-wrap:wrap;gap:12rpx;margin:8rpx 0 18rpx;">
      <image wx:for="{{imageUrls}}" wx:key="index" src="{{item}}" mode="aspectFill" style="width:160rpx;height:160rpx;border-radius:10rpx;background:#f2f3f5;" bindtap="previewImage" data-index="{{index}}" />
    </view>

    <button class="btn-primary" bindtap="submit" loading="{{loading}}" disabled="{{loading}}">立即发布</button>
  </view>
</view>
